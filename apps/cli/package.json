{
	"name": "@miodragmtasic/agentgate-cli",
	"version": "0.1.0",
	"description": "CLI for AgentGate - Permission middleware for AI agents",
	"type": "module",
	"bin": {
		"agentgate": "./dist/agentgate.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "pnpm build && vitest run",
		"typecheck": "tsc --noEmit",
		"dev": "tsx src/bin/agentgate.ts",
		"clean": "rm -rf dist"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/MiodragMTasic/agentgate",
		"directory": "apps/cli"
	},
	"dependencies": {
		"@miodragmtasic/agentgate-core": "0.1.0",
		"yaml": "^2.6.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
