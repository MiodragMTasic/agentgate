{
	"name": "agentgate",
	"private": true,
	"version": "0.0.0",
	"description": "Permission middleware for AI agents",
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"test": "turbo test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "turbo typecheck",
		"validate:realworld": "node ./scripts/validate-realworld.mjs",
		"live:setup": "tsx ./scripts/live/setup.ts",
		"live:openai": "tsx ./scripts/live/openai.ts",
		"live:codex": "tsx ./scripts/live/openai.ts --codex",
		"live:anthropic": "tsx ./scripts/live/anthropic.ts",
		"live:mcp": "tsx ./scripts/live/mcp.ts",
		"live:matrix": "tsx ./scripts/live/matrix.ts",
		"onboarding:serve": "python3 -m http.server 4173 -d docs/onboarding",
		"release:check": "node ./scripts/check-release-readiness.mjs",
		"dispatch:dossier": "python3 ./scripts/build_miodragdev_work_dossier.py",
		"clean": "turbo clean",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm release:check && turbo build && changeset publish"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@biomejs/biome": "^1.9.0",
		"@changesets/cli": "^2.27.0",
		"@miodragmtasic/agentgate-anthropic": "workspace:*",
		"@miodragmtasic/agentgate-core": "workspace:*",
		"@miodragmtasic/agentgate-mcp": "workspace:*",
		"@miodragmtasic/agentgate-openai": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@types/node": "^25.5.0",
		"openai": "^4.104.0",
		"tsx": "^4.21.0",
		"turbo": "^2.3.0",
		"typescript": "^5.7.0"
	}
}
