{
	"name": "@miodragmtasic/agentgate-openai",
	"version": "0.1.0",
	"description": "AgentGate adapter for the OpenAI SDK",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/MiodragMTasic/agentgate",
		"directory": "packages/openai"
	},
	"dependencies": {
		"@miodragmtasic/agentgate-core": "0.1.0"
	},
	"peerDependencies": {
		"openai": ">=4.0.0"
	},
	"devDependencies": {
		"openai": "^4.77.0",
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
